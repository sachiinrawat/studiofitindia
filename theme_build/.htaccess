<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve robots.txt directly (skip WordPress)
  RewriteRule ^robots\.txt$ - [L]

  # WordPress default routing fallback
  RewriteRule ^index\.php$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.php [L]
</IfModule>

# ── Security: Block direct access to sensitive files ──────────────────
<FilesMatch "\.(env|log|sql|bak|sh)$">
  Order allow,deny
  Deny from all
</FilesMatch>
